generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// ============================================
enum UserRole {
  FORNECEDOR
  VENDEDOR
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole
  phone        String?
  document     String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  fornecedorProfile FornecedorProfile?
  meliIntegrations  MeliIntegration[]
  ordersAsSeller    Order[]            @relation("SellerOrders")
  ordersAsSupplier  Order[]            @relation("SupplierOrders")
  productMappings   ProductMapping[]

  @@map("users")
}

// ============================================
// PERFIL DO FORNECEDOR
// ============================================
model FornecedorProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  companyName  String?  @map("company_name")
  address      String?
  city         String?
  state        String?
  zipCode      String?  @map("zip_code")
  shippingType String?  @map("shipping_type")
  shippingDays Int?     @map("shipping_days")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("fornecedor_profiles")
}

// ============================================
// PRODUTOS
// ============================================
enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Product {
  id                  String            @id @default(uuid())
  fornecedorProfileId String            @map("fornecedor_profile_id")
  fornecedor          FornecedorProfile @relation(fields: [fornecedorProfileId], references: [id])

  title          String
  description    String        @db.Text
  costPrice      Decimal       @map("cost_price") @db.Decimal(10, 2)
  suggestedPrice Decimal?      @map("suggested_price") @db.Decimal(10, 2)
  categoryId     String?       @map("category_id")
  brand          String?
  model          String?
  attributes     Json?
  supplierSku    String        @map("supplier_sku")
  stockQuantity  Int           @default(0) @map("stock_quantity")
  status         ProductStatus @default(ACTIVE)

  photos          ProductPhoto[]
  productMappings ProductMapping[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([fornecedorProfileId, supplierSku])
  @@map("products")
}

model ProductPhoto {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("product_photos")
}

// ============================================
// INTEGRAÇÃO MERCADO LIVRE
// ============================================
model MeliIntegration {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  meliUserId     Int       @map("meli_user_id")
  meliNickname   String    @map("meli_nickname")
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime  @map("token_expires_at")
  scopes         String[]
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastSyncAt     DateTime? @map("last_sync_at")

  productMappings ProductMapping[]
  orders          Order[]

  @@unique([userId, meliUserId])
  @@map("meli_integrations")
}

// ============================================
// MAPEAMENTO PRODUTO <-> ANÚNCIO
// ============================================
enum MappingStatus {
  PENDING
  ACTIVE
  OUT_OF_STOCK
  PAUSED
  ERROR
}

model ProductMapping {
  id                String          @id @default(uuid())
  productId         String          @map("product_id")
  product           Product         @relation(fields: [productId], references: [id])
  sellerId          String          @map("seller_id")
  seller            User            @relation(fields: [sellerId], references: [id])
  meliIntegrationId String          @map("meli_integration_id")
  meliIntegration   MeliIntegration @relation(fields: [meliIntegrationId], references: [id])

  meliItemId     String?       @map("meli_item_id")
  meliPermalink  String?       @map("meli_permalink")
  publishedPrice Decimal?      @map("published_price") @db.Decimal(10, 2)
  markupPercent  Decimal?      @map("markup_percent") @db.Decimal(5, 2)
  markupFixed    Decimal?      @map("markup_fixed") @db.Decimal(10, 2)
  status         MappingStatus @default(PENDING)
  syncError      String?       @map("sync_error")
  lastSyncAt     DateTime?     @map("last_sync_at")
  announcedStock Int           @default(0) @map("announced_stock")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  orders Order[]

  @@unique([productId, sellerId])
  @@map("product_mappings")
}

// ============================================
// PEDIDOS
// ============================================
enum OrderStatus {
  CONFIRMED
  PAYMENT_APPROVED
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Order {
  id                String          @id @default(uuid())
  meliOrderId       BigInt          @unique @map("meli_order_id")
  meliOrderStatus   String          @map("meli_order_status")
  sellerId          String          @map("seller_id")
  seller            User            @relation("SellerOrders", fields: [sellerId], references: [id])
  supplierId        String?         @map("supplier_id")
  supplier          User?           @relation("SupplierOrders", fields: [supplierId], references: [id])
  meliIntegrationId String          @map("meli_integration_id")
  meliIntegration   MeliIntegration @relation(fields: [meliIntegrationId], references: [id])
  productMappingId  String?         @map("product_mapping_id")
  productMapping    ProductMapping? @relation(fields: [productMappingId], references: [id])

  buyerName        String?     @map("buyer_name")
  buyerPhone       String?     @map("buyer_phone")
  shippingAddress  Json?       @map("shipping_address")
  totalAmount      Decimal?    @map("total_amount") @db.Decimal(10, 2)
  quantity         Int         @default(1)
  trackingNumber   String?     @map("tracking_number")
  shippingLabel    String?     @map("shipping_label")
  internalStatus   OrderStatus @default(CONFIRMED) @map("internal_status")
  orderDate        DateTime    @map("order_date")
  shippingDeadline DateTime?   @map("shipping_deadline")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  statusHistory    Json?       @map("status_history")

  @@map("orders")
}
